# Orbit backend — environment variables (copy to .env, never commit real values)

# --- Supabase (Orbit project) ---
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...           # service_role key (bypasses RLS) — secret

# --- Anthropic (AI relay) ---
ANTHROPIC_API_KEY=sk-ant-...               # leave empty to disable /api/ai/relay

# --- CORS (comma-separated). Add the real Orbit web domain once registered. ---
ALLOWED_ORIGINS=capacitor://localhost,https://localhost,http://localhost,http://localhost:8000,http://127.0.0.1:8000

# --- AI guardrails (optional; defaults shown) ---
AI_MONTHLY_BUDGET_USD=50
AI_MAX_TOKENS_CEILING=8192

# --- Owner/debug (optional) ---
OWNER_USER_IDS=
DEBUG_KEY=

# --- Set automatically by Railway in prod ---
# RAILWAY_ENVIRONMENT_NAME=production
